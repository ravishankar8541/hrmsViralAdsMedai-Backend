<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Full & Final Settlement Statement</title>
    <style>
        @page {
            margin: 0.5in;
        }
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            color: #333; 
            line-height: 1.5; 
            font-size: 13px; 
            margin: 0;
            padding: 0;
        }

        /* Header Styling matching Viral Ads Media */
        .header-table {
            width: 100%;
            border-bottom: 3px solid #f27022; /* Viral Ads Orange accent */
            padding-bottom: 10px;
            margin-bottom: 20px;
        }
       

        .logo { 
            width: 160px; 
            height: auto; 
        }
        .statement-label {
            text-align: right;
            vertical-align: bottom;
        }
        .statement-title {
            font-size: 18px;
            font-weight: bold;
            color: #f27022;
            text-transform: uppercase;
            margin: 0;
        }

        /* Employee Info Grid */
        .info-section {
            width: 100%;
            margin-bottom: 25px;
            border-collapse: collapse;
        }
        .info-cell {
            width: 50%;
            padding: 5px 0;
            vertical-align: top;
        }
        .label { font-weight: bold; color: #555; width: 140px; display: inline-block; }

        /* Settlement Table */
        .settlement-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
        }
        .settlement-table th {
            background-color: #f27022;
            color: white;
            text-align: left;
            padding: 12px;
            text-transform: uppercase;
            font-size: 12px;
        }
        .settlement-table td {
            padding: 12px;
            border-bottom: 1px solid #eee;
        }
        .amount-col { text-align: right; font-family: 'Courier New', Courier, monospace; font-weight: bold; }
        
        .net-payable-row {
            background-color: #fff5f0;
            font-size: 16px;
            font-weight: bold;
        }
        .net-payable-row td {
            color: #f27022;
            border-top: 2px solid #f27022;
            border-bottom: 2px solid #f27022;
        }

        /* Signatures */
        .signature-section {
            margin-top: 250px;
            width: 100%;
        }
        .sig-box {
            width: 40%;
            padding-top: 40px;
            border-top: 1px solid #000;
            text-align: center;
        }

        .footer {
            position: relative;
            top:200px;
            width: 100%;
            text-align: center;
            font-size: 15px;
            color: #777;
            border-top: 1px solid rgb(245, 215, 215);
            padding-top: 10px;
        }

        /* ====================== NEW ADDED STYLES (nothing removed) ====================== */
        .bank-details {
            margin-top: 15px;
            font-size: 12px;
            color: #444;
        }
    </style>
</head>
<body>

    <table class="header-table">
        <tr>
            <td>
                <img src="<%= logo %>" class="logo"> </td>
            <td class="statement-label">
                <p class="statement-title">Full & Final Statement</p> <span style="font-size: 11px;">Date of Issue: <%= currentDate %></span>
            </td>
        </tr>
    </table>

    <table class="info-section">
        <tr>
            <td class="info-cell">
                <span class="label">Employee Name:</span> <strong><%= employeeName %></strong><br> 
                <span class="label">Employee ID:</span> <%= typeof employeeId !== 'undefined' ? employeeId : 'N/A' %><br>
                <span class="label">Designation:</span> <%= typeof designation !== 'undefined' ? designation : 'Employee' %><br>
                <span class="label">Account No:</span><%= typeof bankAccount !== 'undefined' ? bankAccount : 'N/A' %><br>
                <span class="label">Address:</span> <%= typeof address !== 'undefined' ? address : 'N/A' %>
            </td>
            <td class="info-cell">
                <span class="label">Date of Joining:</span> <%= dateOfJoining %><br> 
                <span class="label">Last Working Day:</span> <%= lastWorkingDay %><br> 
                <span class="label">Contact:</span> <%= phone %> <br>
                <span class="label">IFSC:</span><%= typeof ifsc !== 'undefined' ? ifsc : 'N/A' %><br>
                <span class="label">Email:</span><%= email %> <br>
            </td>
        </tr>
    </table>

    <!-- ====================== NEW ADDED SECTION (nothing removed) ====================== -->
   

    <table class="settlement-table">
        <thead>
            <tr>
                <th>Particulars</th> <th style="text-align: right;">Amount (INR)</th> </tr>
        </thead>
        <tbody>
            <tr>
                <td>Pending Salary / Basic Pay</td>
                <td class="amount-col"><%= pendingSalary %></td> </tr>
            <tr>
                <td>Leave Encashment</td>
                <td class="amount-col"><%= leaveEncashment %></td> </tr>
            <tr>
                <td>Bonus / Performance Incentive</td>
                <td class="amount-col"><%= incentive %></td> </tr>
            <tr>
                <td>Other Allowances</td>
                <td class="amount-col">0.00</td>
            </tr>
            <tr>
                <td style="color: #d32f2f;">Deductions (TDS/LWP/Notice Recovery)</td>
                <td class="amount-col" style="color: #d32f2f;">- <%= deductions %></td> </tr>
            <tr class="net-payable-row">
                <td>NET PAYABLE AMOUNT</td> <td class="amount-col">₹ <%= totalPayable %></td> </tr>
        </tbody>
    </table>

    <p style="font-size: 11px; margin-top: 20px; font-style: italic;">
        * This is a computer-generated statement. The net payable amount will be credited to your bank account registered with Viral Ads Media.
    </p>

    <table class="signature-section">
        <tr>
            <td class="sig-box">
                <strong>Prepared By</strong><br> HR & Accounts Department<br>
                Viral Ads Media </td>
            <td style="width: 10%;"></td>
            <td class="sig-box">
                <strong>Employee Acknowledgment</strong><br> Name: <%= employeeName %> </td>
        </tr>
    </table>

    <div class="footer">
        <strong>Viral Ads Media</strong> | Digital Creative Agency <br>
        <%= companyAddress %> </div>

</body>
</html>