<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <style>
        @page {
            margin: 0.7in;
            /* thoda kam margin */
        }

        body {
            font-family: 'Times New Roman', Times, serif;
            color: #111;
            line-height: 1.6;
            font-size: 14.5px;
            /* balanced size */
            margin: 0;
            padding: 0;
        }

        /* Header */
        .header-table {
            width: 100%;
            border-bottom: 2px solid #f27022;
            padding-bottom: 12px;
            margin-bottom: 25px;
        }

        .logo {
            width: 200px;
        }

        .company-name {
            font-size: 24px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .tagline {
            font-size: 11px;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #555;
            font-weight: bold;
        }

        .ref-info {
            text-align: right;
            font-size: 13px;
            line-height: 1.6;
        }

        /* Body */
        .title {
            text-align: center;
            font-size: 20px;
            font-weight: bold;
            margin: 25px 0 18px 0;
            text-transform: uppercase;
            text-decoration: underline;
        }

        .address-block {
            margin-bottom: 20px;
            line-height: 1.5;
        }

        .subject {
            font-weight: bold;
            margin: 15px 0;
            font-style: italic;
        }

        .content {
            text-align: justify;
        }

        .terms-list {
            padding-left: 20px;
            margin: 12px 0;
            list-style: none;
        }

        .terms-list li {
            margin-bottom: 8px;
        }

        .terms-list li::before {
            content: "•";
            color: #f27022;
            font-weight: bold;
            display: inline-block;
            width: 1em;
            margin-left: -1em;
        }

        .standards-box {
            background: #fafafa;
            border: 1px solid #eee;
            padding: 12px;
            margin: 18px 0;
            font-size: 13.5px;
            border-left: 4px solid #f27022;
        }

        /* Signature */
        .signature-table {
            width: 100%;
            margin-top: 200px;
        }

        .signature-table td {
            vertical-align: top;
            font-size: 14.5px;
        }

        .sig-space {
            height: 50px;
        }

        /* Footer */
        .footer-container {
            position: relative;
            top:10px;
            margin-top: 100px;
            font-size: 11px;
            color: #333;
        }

        .footer-divider {
            border-top: 2px solid #f27022;
            margin-bottom: 6px;
        }

        .footer-content {
            text-align: center;
            line-height: 1.6;
        }

        .footer-company {
            font-weight: bold;
            font-size: 12px;
        }

        .footer-address {
            font-size: 10.5px;
            color: #555;
        }
    </style>
</head>

<body>

    <table class="header-table">
        <tr>
            <td style="width: 60%;">
                <% if (locals.logo) { %>
                    <img src="<%= logo %>" class="logo">
                    <% } else { %>
                        <div class="company-name">Viral Ads Media</div>
                        <div class="tagline">Digital Creative Agency</div>
                        <% } %>
            </td>
            <td class="ref-info">
                <strong>Ref No:</strong>
                <%= offerId %><br>
                    <strong>Date:</strong>
                    <%= locals.currentDate || new Date().toLocaleDateString('en-GB', { day: 'numeric' , month: 'long' ,
                        year: 'numeric' }) %>
            </td>
        </tr>
    </table>

    <div class="address-block">
        To,<br>
        <span class="highlight" style="font-size: 16px;">
            <%= locals.employeeName %>
        </span><br>
        <% if (locals.fathersName) { %> S/O: <%= locals.fathersName %><br>
                <% } %>
                    <%= locals.address %><br>
                        <%= locals.phoneNumber %><br>
                            <%= locals.emailId %>
    </div>

    <div class="title">Letter of Employment Offer</div>

    <div class="content">
        <p>Dear <span class="highlight">
                <%= employeeName %>
            </span>,</p>

        <p>We are pleased to formally offer you the position of <span class="highlight">
                <%= position %>
            </span> at <span class="highlight">Viral Ads Media</span>.
            Based on our evaluation of your skills and experience, we are confident that you will make significant
            contributions to our team's creative excellence.</p>

        <p class="subject">Subject: Appointment for the position of <%= position %>.</p>

        <p>Your employment will be governed by the following key terms and conditions:</p>

        <ul class="terms-list">
            <li>
                <strong>Commencement:</strong>
                <%= formattedJoiningDate || 'Pending' %>
            </li>

            <li><strong>Remuneration:</strong> <span class="highlight">₹<%= salary.toLocaleString('en-IN') %>/-</span>
                (Inclusive of all statutory allowances)</li>
            <li><strong>Probation:</strong> Three (3) Months</li>
            <li><strong>Location:</strong> Delhi</li>
        </ul>

        <div class="standards-box">
            <strong>Professional Standards:</strong> You are expected to maintain high levels of confidentiality and
            integrity.
            All intellectual property created during your tenure remains the property of the agency.
        </div>

        
    </div>

   <table class="signature-table">
    <tr>
        <td style="width: 50%;">

            <p style="margin-bottom: 10px; font-weight: bold;">
                Best Regards,
            </p>

            <p style="margin: 0;">
                <strong>Viral Ads Media</strong>
            </p>

            <p style="margin-top: 2px;">
                HR Department
            </p>

        </td>
    </tr>
</table>



    <div class="footer-container">
        <div class="footer-divider"></div>

        <div class="footer-content">
            <div class="footer-company">
                Viral Ads Media | Digital Creative Agency
            </div>

            <div class="footer-address">
                B-27, Budh Vihar Phase 1, New Delhi - 110086
                | +91 93544 91934
            </div>
        </div>
    </div>
</body>

</html>